HOST=0.0.0.0
PORT=1337
# Публичный URL Strapi в браузере (без слэша в конце): поддомен админки или https://site.ru/cp за nginx.
APP_URL=https://example-admin.example.com
# Доверие Koa к X-Forwarded-Proto / Host (nginx). По умолчанию true в config/server.ts.
# STRAPI_PROXY_KOA=true
# В production по умолчанию Secure-cookies; для отладки по HTTP: SESSION_COOKIE_SECURE=false
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified
